shamefully-hoist=true
strict-peer-dependencies=false
legacy-peer-deps=true
# Keep the pnpm virtual store at a short absolute path. Without this,
# node_modules/.pnpm/react-native@<long-peer-hash>/node_modules/react-native/
# ReactAndroid/.../NativeMethodCallInvokerHolder.h exceeds Windows MAX_PATH
# (260) and ninja fails during expo-modules-core's CMake build.
virtual-store-dir=D:/.pnpm-vs
