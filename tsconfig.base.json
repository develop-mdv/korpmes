{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "paths": {
      "@corp/shared-types": ["./packages/shared-types/src"],
      "@corp/shared-validation": ["./packages/shared-validation/src"],
      "@corp/shared-constants": ["./packages/shared-constants/src"]
    }
  },
  "exclude": ["node_modules", "dist"]
}
