{
  "name": "@corp/api",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "nest build",
    "dev": "ts-node -P tsconfig.json -r tsconfig-paths/register --files src/main.ts",
    "start": "node dist/apps/api/src/main",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/apps/api/src/main",
    "lint": "echo 'no eslint configured'",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:e2e": "jest --config ./jest.e2e.config.ts",
    "typecheck": "tsc --noEmit",
    "db:migrate": "ts-node -P tsconfig.json ./node_modules/typeorm/cli.js migration:run -d src/database/typeorm.datasource.ts",
    "db:migrate:revert": "ts-node -P tsconfig.json ./node_modules/typeorm/cli.js migration:revert -d src/database/typeorm.datasource.ts",
    "db:migrate:generate": "ts-node -P tsconfig.json ./node_modules/typeorm/cli.js migration:generate -d src/database/typeorm.datasource.ts",
    "db:seed": "ts-node -P tsconfig.json src/database/seeds/seed.ts"
  },
  "dependencies": {
    "@corp/shared-constants": "workspace:*",
    "@corp/shared-types": "workspace:*",
    "@corp/shared-validation": "workspace:*",
    "@nestjs/bull": "^10.2.0",
    "@nestjs/common": "^10.4.0",
    "@nestjs/config": "^3.3.0",
    "@nestjs/core": "^10.4.0",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/passport": "^10.0.0",
    "@nestjs/platform-express": "^10.4.0",
    "@nestjs/platform-socket.io": "^10.4.0",
    "@nestjs/swagger": "^7.4.0",
    "@nestjs/typeorm": "^10.0.0",
    "@nestjs/websockets": "^10.4.0",
    "bcrypt": "^5.1.0",
    "bull": "^4.16.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.0",
    "dotenv": "^17.4.1",
    "ioredis": "^5.4.0",
    "minio": "^8.0.0",
    "otplib": "^12.0.0",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.0",
    "pg": "^8.13.0",
    "reflect-metadata": "^0.2.0",
    "rxjs": "^7.8.0",
    "sharp": "^0.33.0",
    "socket.io": "^4.8.0",
    "typeorm": "^0.3.20",
    "uuid": "^10.0.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.0",
    "@nestjs/schematics": "^10.2.0",
    "@nestjs/testing": "^10.4.0",
    "@types/bcrypt": "^5.0.0",
    "@types/express": "^5.0.0",
    "@types/jest": "^29.5.0",
    "@types/multer": "^1.4.0",
    "@types/node": "^22.0.0",
    "@types/passport-jwt": "^4.0.0",
    "@types/uuid": "^10.0.0",
    "jest": "^29.7.0",
    "source-map-support": "^0.5.0",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.0",
    "ts-node": "^10.9.0",
    "typescript": "^5.7.0"
  }
}
